---
import { profile, contact, stats, resume } from "../data/cv";

const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const resumeHref = `${base}/${resume.file}`;
---

<section id="top" class="hero">
  <div class="container hero-grid">
    <div class="hero-text">
      <p class="section-label" data-reveal>online · disponible para proyectos</p>

      <h1 data-reveal style="--reveal-delay: 80ms">
        {profile.name}
      </h1>

      <p class="role mono accent" data-reveal style="--reveal-delay: 160ms">
        <span class="prompt">$</span>
        <span id="typed" data-text={profile.title}></span><span class="cursor">▋</span>
      </p>

      <p class="tagline" data-reveal style="--reveal-delay: 240ms">
        {profile.tagline}
      </p>

      <p class="summary" data-reveal style="--reveal-delay: 320ms">
        {profile.summary}
      </p>

      <div class="cta" data-reveal style="--reveal-delay: 400ms">
        <a class="btn primary" href="#contacto">Contactame</a>
        <a class="btn download" href={resumeHref} download>
          <span class="mono">↓</span> {resume.label}
        </a>
        <a class="btn ghost" href="#proyectos">Ver proyectos →</a>
      </div>
    </div>

    <aside class="hero-card" data-reveal="scale" style="--reveal-delay: 200ms" data-parallax="0.08">
      <div class="card-head mono">
        <span class="dot red"></span><span class="dot yellow"></span><span class="dot green"></span>
        <span class="filename">profile.json</span>
      </div>
      <pre class="code"><code><span class="k">{`{`}</span>
  <span class="key">"rol"</span>: <span class="str">"Technical Lead"</span>,
  <span class="key">"foco"</span>: <span class="str">"Full Stack · Cloud"</span>,
  <span class="key">"equipo"</span>: <span class="num">9</span>,
  <span class="key">"stack"</span>: [<span class="str">"TS"</span>, <span class="str">"Node"</span>, <span class="str">"React"</span>],
  <span class="key">"cloud"</span>: [<span class="str">"AWS"</span>, <span class="str">"Azure"</span>],
  <span class="key">"disponible"</span>: <span class="bool">true</span>
<span class="k">{`}`}</span></code></pre>
    </aside>
  </div>

  <ul class="stats container" data-reveal style="--reveal-delay: 480ms">
    {
      stats.map((s) => (
        <li>
          <span class="stat-val mono accent">{s.value}</span>
          <span class="stat-label">{s.label}</span>
        </li>
      ))
    }
  </ul>
</section>

<script>
  // Efecto typing en el rol
  const el = document.getElementById("typed");
  const reduce = window.matchMedia("(prefers-reduced-motion: reduce)").matches;
  if (el) {
    const text = el.dataset.text || "";
    if (reduce) {
      el.textContent = text;
    } else {
      let i = 0;
      const tick = () => {
        el.textContent = text.slice(0, i);
        i++;
        if (i <= text.length) setTimeout(tick, 45);
      };
      setTimeout(tick, 500);
    }
  }
</script>

<style>
  .hero {
    padding-top: 4rem;
    padding-bottom: 3rem;
  }
  .hero-grid {
    display: grid;
    grid-template-columns: 1.4fr 1fr;
    gap: 3rem;
    align-items: center;
  }
  h1 {
    font-size: clamp(2.4rem, 6vw, 4.2rem);
    font-weight: 800;
    letter-spacing: -0.03em;
    line-height: 1.02;
    margin-block: 0.5rem 1rem;
    background: linear-gradient(180deg, var(--text) 60%, var(--text-soft));
    -webkit-background-clip: text;
    background-clip: text;
    color: transparent;
  }
  .role {
    font-size: clamp(1rem, 2.5vw, 1.35rem);
    margin-bottom: 1rem;
  }
  .prompt {
    color: var(--text-dim);
  }
  .cursor {
    color: var(--accent);
    animation: blink 1s step-end infinite;
  }
  @keyframes blink {
    50% {
      opacity: 0;
    }
  }
  .tagline {
    color: var(--cyan);
    font-size: 1.05rem;
    margin-bottom: 1.25rem;
  }
  .summary {
    color: var(--text-soft);
    font-size: 1rem;
    max-width: 60ch;
    margin-bottom: 2rem;
  }
  .cta {
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
  }
  .btn {
    padding: 0.8rem 1.5rem;
    border-radius: 10px;
    font-weight: 600;
    font-size: 0.95rem;
    transition: all 0.25s var(--ease);
    border: 1px solid transparent;
  }
  .btn.primary {
    background: var(--accent);
    color: #06210d;
    box-shadow: 0 0 0 0 var(--accent-glow);
  }
  .btn.primary:hover {
    box-shadow: 0 8px 30px -6px var(--accent-glow);
    transform: translateY(-2px);
  }
  .btn.ghost {
    border-color: var(--border-glow);
    color: var(--text);
  }
  .btn.ghost:hover {
    border-color: var(--accent);
    color: var(--accent);
    transform: translateY(-2px);
  }
  .btn.download {
    border-color: var(--cyan);
    color: var(--cyan);
    background: color-mix(in srgb, var(--cyan) 8%, transparent);
  }
  .btn.download:hover {
    background: color-mix(in srgb, var(--cyan) 16%, transparent);
    transform: translateY(-2px);
  }

  /* Tarjeta de código */
  .hero-card {
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    overflow: hidden;
    box-shadow: 0 24px 60px -20px rgba(0, 0, 0, 0.6);
  }
  .card-head {
    display: flex;
    align-items: center;
    gap: 0.45rem;
    padding: 0.75rem 1rem;
    background: var(--bg-soft);
    border-bottom: 1px solid var(--border);
    font-size: 0.8rem;
    color: var(--text-dim);
  }
  .dot {
    width: 11px;
    height: 11px;
    border-radius: 50%;
  }
  .dot.red {
    background: #ff5f56;
  }
  .dot.yellow {
    background: #ffbd2e;
  }
  .dot.green {
    background: #27c93f;
  }
  .filename {
    margin-left: auto;
  }
  .code {
    margin: 0;
    padding: 1.25rem 1.4rem;
    font-family: var(--font-mono);
    font-size: 0.9rem;
    line-height: 1.8;
    overflow-x: auto;
  }
  .code .k {
    color: var(--text-soft);
  }
  .code .key {
    color: var(--cyan);
  }
  .code .str {
    color: var(--accent);
  }
  .code .num {
    color: #f0883e;
  }
  .code .bool {
    color: #d2a8ff;
  }

  /* Stats */
  .stats {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1.5rem;
    margin-top: 4rem;
    padding-top: 2.5rem;
    border-top: 1px solid var(--border);
    list-style: none;
  }
  .stats li {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }
  .stat-val {
    font-size: clamp(1.5rem, 4vw, 2.2rem);
    font-weight: 700;
  }
  .stat-label {
    color: var(--text-dim);
    font-size: 0.85rem;
  }

  @media (max-width: 860px) {
    .hero-grid {
      grid-template-columns: 1fr;
    }
    .hero-card {
      order: -1;
    }
    .stats {
      grid-template-columns: repeat(2, 1fr);
    }
  }
</style>

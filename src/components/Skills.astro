---
import { skills } from "../data/cv";
---

<section id="skills">
  <div class="container">
    <p class="section-label" data-reveal>competencias técnicas</p>
    <h2 class="section-title" data-reveal style="--reveal-delay: 80ms">
      Stack & herramientas
    </h2>

    <div class="grid">
      {
        skills.map((group, i) => (
          <article class="card" data-reveal style={`--reveal-delay: ${i * 90}ms`}>
            <h3>{group.category}</h3>
            {group.subgroups.map((sg) => (
              <div class="subgroup">
                <span class="sg-label mono">{sg.label}</span>
                <ul class="chips">
                  {sg.items.map((item) => (
                    <li>{item}</li>
                  ))}
                </ul>
              </div>
            ))}
          </article>
        ))
      }
    </div>
  </div>
</section>

<style>
  .grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: 1.25rem;
  }
  .card {
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    padding: 1.5rem;
    transition:
      transform 0.3s var(--ease),
      border-color 0.3s var(--ease),
      box-shadow 0.3s var(--ease);
  }
  .card:hover {
    transform: translateY(-4px);
    border-color: var(--border-glow);
    box-shadow: 0 18px 40px -22px rgba(0, 0, 0, 0.7);
  }
  h3 {
    font-size: 1.05rem;
    margin-bottom: 1.1rem;
    color: var(--text);
  }
  .subgroup {
    margin-bottom: 1rem;
  }
  .subgroup:last-child {
    margin-bottom: 0;
  }
  .sg-label {
    display: block;
    font-size: 0.75rem;
    color: var(--text-dim);
    text-transform: uppercase;
    letter-spacing: 0.06em;
    margin-bottom: 0.5rem;
  }
  .chips {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
    list-style: none;
  }
  .chips li {
    font-size: 0.82rem;
    padding: 0.28rem 0.65rem;
    border-radius: 7px;
    background: var(--bg-soft);
    border: 1px solid var(--border);
    color: var(--text-soft);
    transition:
      color 0.2s var(--ease),
      border-color 0.2s var(--ease),
      background 0.2s var(--ease);
  }
  .chips li:hover {
    color: var(--accent);
    border-color: var(--accent);
    background: var(--accent-dim);
  }
</style>

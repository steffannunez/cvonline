---
import { contact, profile } from "../data/cv";
---

<section id="contacto" class="contact">
  <div class="container" data-reveal="scale">
    <div class="panel" data-parallax="0.05">
      <p class="section-label">contacto</p>
      <h2>¿Construimos algo juntos?</h2>
      <p class="lead">
        Estoy abierto a nuevos desafíos, colaboraciones y proyectos. Escribime y conversamos.
      </p>

      <div class="links">
        <a class="link" href={`mailto:${contact.email}`}>
          <span class="ico mono">@</span>
          <span>{contact.email}</span>
        </a>
        <a class="link" href={`tel:${contact.phone.replace(/[^+\d]/g, "")}`}>
          <span class="ico mono">☎</span>
          <span>{contact.phone}</span>
        </a>
        <div class="link static">
          <span class="ico mono">#</span>
          <span>{contact.handle}</span>
        </div>
      </div>
    </div>

    <footer class="foot mono">
      <span>© {new Date().getFullYear()} {profile.name}</span>
      <span class="built">construido con Astro · sin frameworks pesados</span>
    </footer>
  </div>
</section>

<style>
  .contact {
    padding-bottom: 4rem;
  }
  .panel {
    background:
      linear-gradient(180deg, var(--bg-card), var(--bg-soft));
    border: 1px solid var(--border);
    border-radius: 20px;
    padding: clamp(2rem, 5vw, 3.5rem);
    text-align: center;
    position: relative;
    overflow: hidden;
  }
  .panel::before {
    content: "";
    position: absolute;
    inset: 0;
    background: radial-gradient(500px circle at 50% -10%, var(--accent-dim), transparent 60%);
    pointer-events: none;
  }
  h2 {
    font-size: clamp(1.8rem, 5vw, 2.8rem);
    font-weight: 700;
    letter-spacing: -0.02em;
    margin-bottom: 0.75rem;
  }
  .lead {
    color: var(--text-soft);
    max-width: 48ch;
    margin: 0 auto 2.25rem;
  }
  .links {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 0.9rem;
  }
  .link {
    display: inline-flex;
    align-items: center;
    gap: 0.6rem;
    padding: 0.8rem 1.3rem;
    border-radius: 10px;
    border: 1px solid var(--border);
    background: var(--bg);
    color: var(--text);
    font-size: 0.95rem;
    transition: all 0.25s var(--ease);
  }
  a.link:hover {
    border-color: var(--accent);
    color: var(--accent);
    transform: translateY(-2px);
  }
  .link.static {
    color: var(--text-soft);
  }
  .ico {
    color: var(--accent);
    font-weight: 600;
  }
  .foot {
    display: flex;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin-top: 2.5rem;
    font-size: 0.8rem;
    color: var(--text-dim);
  }
</style>

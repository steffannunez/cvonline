---
import { projects } from "../data/cv";
---

<section id="proyectos">
  <div class="container">
    <p class="section-label" data-reveal>portfolio</p>
    <h2 class="section-title" data-reveal style="--reveal-delay: 80ms">
      Proyectos destacados
    </h2>

    <div class="grid">
      {
        projects.map((p, i) => {
          const Tag = p.url ? "a" : "div";
          return (
            <Tag
              class="project"
              href={p.url}
              target={p.url ? "_blank" : undefined}
              rel={p.url ? "noopener noreferrer" : undefined}
              data-reveal="scale"
              style={`--reveal-delay: ${(i % 3) * 90}ms`}
            >
              <div class="top">
                <span class="glyph mono">{"</>"}</span>
                {p.url && <span class="ext mono">↗</span>}
              </div>
              <h3>{p.name}</h3>
              <p class="desc">{p.description}</p>
              <ul class="stack">
                {p.stack.map((s) => (
                  <li class="mono">{s}</li>
                ))}
              </ul>
            </Tag>
          );
        })
      }
    </div>
  </div>
</section>

<style>
  .grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(290px, 1fr));
    gap: 1.25rem;
  }
  .project {
    display: flex;
    flex-direction: column;
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    padding: 1.5rem;
    position: relative;
    overflow: hidden;
    transition:
      transform 0.3s var(--ease),
      border-color 0.3s var(--ease),
      box-shadow 0.3s var(--ease);
  }
  .project::before {
    content: "";
    position: absolute;
    inset: 0;
    background: radial-gradient(400px circle at var(--mx, 50%) var(--my, 0%), var(--accent-dim), transparent 60%);
    opacity: 0;
    transition: opacity 0.3s var(--ease);
    pointer-events: none;
  }
  .project:hover {
    transform: translateY(-6px);
    border-color: var(--accent);
    box-shadow: 0 22px 50px -24px var(--accent-glow);
  }
  .project:hover::before {
    opacity: 1;
  }
  .top {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 1rem;
  }
  .glyph {
    color: var(--accent);
    font-size: 1.2rem;
    font-weight: 600;
  }
  .ext {
    color: var(--text-dim);
  }
  h3 {
    font-size: 1.15rem;
    margin-bottom: 0.55rem;
  }
  .desc {
    color: var(--text-soft);
    font-size: 0.92rem;
    flex: 1;
    margin-bottom: 1.2rem;
  }
  .stack {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
    list-style: none;
  }
  .stack li {
    font-size: 0.72rem;
    padding: 0.22rem 0.55rem;
    border-radius: 6px;
    color: var(--cyan);
    border: 1px solid var(--border);
    background: var(--bg-soft);
  }
</style>

<script>
  // Glow que sigue al cursor dentro de cada tarjeta
  const cards = document.querySelectorAll<HTMLElement>(".project");
  cards.forEach((card) => {
    card.addEventListener("pointermove", (e) => {
      const r = card.getBoundingClientRect();
      card.style.setProperty("--mx", `${e.clientX - r.left}px`);
      card.style.setProperty("--my", `${e.clientY - r.top}px`);
    });
  });
</script>

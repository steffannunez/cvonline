---
import { experience } from "../data/cv";
---

<section id="experiencia">
  <div class="container">
    <p class="section-label" data-reveal>trayectoria</p>
    <h2 class="section-title" data-reveal style="--reveal-delay: 80ms">
      Experiencia profesional
    </h2>

    <div class="timeline">
      {
        experience.map((job, i) => (
          <article class="item" data-reveal={i % 2 === 0 ? "left" : "right"}>
            <span class="node" aria-hidden="true" />
            <div class="content">
              <div class="head">
                <h3>
                  {job.role}
                  <span class="at"> · {job.company}</span>
                </h3>
                {job.context && <p class="context">{job.context}</p>}
                <p class="meta mono">
                  <span class="period">{job.period}</span>
                  <span class="sep">—</span>
                  <span>{job.location}</span>
                </p>
              </div>

              <ul class="highlights">
                {job.highlights.map((h) => (
                  <li>{h}</li>
                ))}
              </ul>

              {job.tags && (
                <ul class="tags">
                  {job.tags.map((t) => (
                    <li class="mono">{t}</li>
                  ))}
                </ul>
              )}
            </div>
          </article>
        ))
      }
    </div>
  </div>
</section>

<style>
  .timeline {
    position: relative;
    padding-left: 2rem;
  }
  .timeline::before {
    content: "";
    position: absolute;
    left: 5px;
    top: 6px;
    bottom: 6px;
    width: 2px;
    background: linear-gradient(180deg, var(--accent), var(--border) 85%);
  }
  .item {
    position: relative;
    padding-bottom: 2.75rem;
  }
  .item:last-child {
    padding-bottom: 0;
  }
  .node {
    position: absolute;
    left: -1.95rem;
    top: 7px;
    width: 12px;
    height: 12px;
    border-radius: 50%;
    background: var(--bg);
    border: 2px solid var(--accent);
    box-shadow: 0 0 0 4px var(--accent-dim);
  }
  .content {
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    padding: 1.4rem 1.6rem;
    transition:
      transform 0.3s var(--ease),
      border-color 0.3s var(--ease);
  }
  .content:hover {
    transform: translateX(4px);
    border-color: var(--border-glow);
  }
  h3 {
    font-size: 1.1rem;
    font-weight: 600;
  }
  .at {
    color: var(--accent);
    font-weight: 500;
  }
  .context {
    color: var(--cyan);
    font-size: 0.88rem;
    margin-top: 0.15rem;
  }
  .meta {
    font-size: 0.8rem;
    color: var(--text-dim);
    margin-top: 0.4rem;
    display: flex;
    gap: 0.5rem;
    flex-wrap: wrap;
  }
  .period {
    color: var(--text-soft);
  }
  .sep {
    opacity: 0.5;
  }
  .highlights {
    margin: 1rem 0 0;
    padding-left: 0;
    list-style: none;
    display: grid;
    gap: 0.55rem;
  }
  .highlights li {
    position: relative;
    padding-left: 1.4rem;
    color: var(--text-soft);
    font-size: 0.93rem;
  }
  .highlights li::before {
    content: "▹";
    position: absolute;
    left: 0;
    color: var(--accent);
  }
  .tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
    margin-top: 1.1rem;
    list-style: none;
  }
  .tags li {
    font-size: 0.72rem;
    padding: 0.22rem 0.55rem;
    border-radius: 6px;
    color: var(--text-dim);
    border: 1px solid var(--border);
    background: var(--bg-soft);
  }
</style>
